{
  "expo": {
    "name": "plantalia3",
    "slug": "plantalia3",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080f08"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Plantalia potrzebuje aparatu do fotografowania roślin.",
        "NSPhotoLibraryUsageDescription": "Plantalia potrzebuje galerii do wyboru zdjęć roślin."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Plantalia potrzebuje dostępu do galerii.",
          "cameraPermission": "Plantalia potrzebuje dostępu do aparatu."
        }
      ]
    ]
  }
}
